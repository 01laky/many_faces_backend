# Development Environment Variables for BeDemo API
# Copy this file to .env and update values as needed (if using .env file)
# Note: Environment variables are typically set in docker-compose.dev.yml

# ASP.NET Core Environment
# Values: Development, Production, Testing
ASPNETCORE_ENVIRONMENT=Development

# ASP.NET Core URLs (semicolon-separated)
# Format: http://0.0.0.0:PORT;https://0.0.0.0:PORT
ASPNETCORE_URLS=http://0.0.0.0:8000;https://0.0.0.0:8001

# HTTPS Certificate Configuration
ASPNETCORE_Kestrel__Certificates__Default__Password=
ASPNETCORE_Kestrel__Certificates__Default__Path=/app/https/dev-cert.pfx

# Database Connection String
# Format: Host=HOST;Port=PORT;Database=DATABASE;Username=USER;Password=PASSWORD
# From Docker containers: use host.docker.internal
# From localhost: use localhost
ConnectionStrings__DefaultConnection=Host=host.docker.internal;Port=54320;Database=bedemo;Username=bedemo_user;Password=bedemo_password

# Serilog Configuration (Structured Logging)
# Seq server URL for log viewing
Serilog__WriteTo__0__Name=Seq
Serilog__WriteTo__0__Args__serverUrl=http://seq:5341

# AI Service gRPC Address (optional)
# Default: ai-demo-dev:50051 (Docker service name)
AI_SERVICE_GRPC_ADDRESS=ai-demo-dev:50051
