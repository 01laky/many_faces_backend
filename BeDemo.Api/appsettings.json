{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Identity": {
    "Password": {
      "RequiredLength": 12
    }
  },
  "Jwt": {
    "Issuer": "BeDemoApi",
    "Audience": "BeDemoApi",
    "ExpiresInMinutes": 60,
    "ExpiresInMinutesRememberMe": 10080,
    "RefreshTokenDaysSession": 14,
    "RefreshTokenDaysRememberMe": 90,
    "SigningPemPath": "",
    "KeyId": "",
    "PreviousSigningPemPath": "",
    "PreviousKeyId": ""
  },
  "Cors": {
    "Origins": []
  },
  "Swagger": {
    "EnableInProduction": false
  },
  "OAuth2": {
    "ClientId": "be-demo-client",
    "ClientSecret": "CHANGE_ME_oauth_client_secret_min_32_chars",
    "BypassRateLimitInTesting": true,
    "TokenRateLimitPermitLimit": 60,
    "TokenRateLimitWindowSeconds": 60,
    "RegisterRateLimitPermitLimit": 30,
    "RegisterRateLimitWindowSeconds": 60
  },
  "Auth": {
    "LoginRateLimitPermitLimit": 30,
    "LoginRateLimitWindowSeconds": 60
  },
  "RateLimit": {
    "ApiPermitLimit": 600,
    "ApiWindowSeconds": 60
  },
  "Localization": {
    "RateLimitPermitLimit": 120,
    "RateLimitWindowSeconds": 60
  },
  "ChatHub": {
    "SendAiMaxPerWindow": 30,
    "SendAiWindowSeconds": 60
  },
  "AiService": {
    "GrpcAddress": "http://ai-demo-dev:50051",
    "WorkerTlsServerCaPath": "",
    "WorkerTlsClientCertPath": "",
    "WorkerTlsClientKeyPath": "",
    "WorkerGrpcTlsServerName": "",
    "WorkerAuthToken": ""
  },
  "AiStats": {
    "PublicSnapshotAbsoluteUrl": ""
  },
  "Retention": {
    "Enabled": false,
    "Execute": false,
    "IntervalHours": 24
  },
  "ErrorHandling": {
    "UseProblemDetails": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "Redis": {
    "Configuration": ""
  },
  "RedisJobWorker": {
    "PollMilliseconds": 750
  },
  "ContentModeration": {
    "InstructionHeuristicEnabled": true
  },
  "Performance": {
    "AccessTokenVersionCacheSeconds": 45,
    "FacesConfigCacheSeconds": 120,
    "CapabilitiesCacheSeconds": 45,
    "PlatformStatsCacheSeconds": 45,
    "PublicStatsCacheSeconds": 60,
    "AdminSearchAutocompleteCacheSeconds": 15,
    "SearchOutboxMaxParallelGrpc": 4,
    "EfQueryTagsEnabled": false,
    "UploadServeCacheMaxAgeSeconds": 300,
    "HubUserDisplayCacheSeconds": 60,
    "SearchGrpcDeadlineSeconds": 15
  },
  "Search": {
    "Enabled": false,
    "WorkerGrpcUrl": "",
    "WorkerTlsServerCaPath": "",
    "WorkerTlsClientCertPath": "",
    "WorkerTlsClientKeyPath": "",
    "WorkerGrpcTlsServerName": "",
    "WorkerAuthToken": "",
    "GrpcDeadlineSeconds": 10,
    "IndexPrefix": "manyfaces",
    "ReconciliationEnabled": true,
    "ReconciliationIntervalHours": 6,
    "ReconciliationStartupDelaySeconds": 30,
    "ReconciliationBatchSize": 200,
    "ReconciliationRunTimeoutMinutes": 45,
    "OutboxPollIntervalSeconds": 5,
    "OutboxWarningPendingCount": 1000
  },
  "Uploads": {
    "SigningSecret": "CHANGE_ME_upload_signing_secret_32chars!!",
    "SignedUrlLifetimeMinutes": 60
  },
  "RegistrationInvite": {
    "HmacPepper": "CHANGE_ME_registration_invite_pepper_32"
  },
  "OperatorAi": {
    "MaxHistoryPairs": 5,
    "MaxMessageLength": 16000,
    "MaxConversationsListPageSize": 50,
    "MaxConversations": 1000,
    "MessagesPageSize": 40,
    "MaxNewTokens": 384,
    "AttachStatsOnlyForMetricsQuestions": true,
    "IncludeTimeseriesInStatsContext": true
  },
  "Push": {
    "Enabled": false,
    "WorkerGrpcUrl": "",
    "WorkerTlsServerCaPath": "",
    "WorkerTlsClientCertPath": "",
    "WorkerTlsClientKeyPath": "",
    "WorkerGrpcTlsServerName": "",
    "WorkerAuthToken": "",
    "GrpcDeadlineSeconds": 15
  },
  "HardenedSecurity": {
    "CertificateRevocationMode": "NoCheck"
  }
}
