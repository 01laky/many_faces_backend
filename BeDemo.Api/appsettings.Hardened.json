{
  "AllowedHosts": "api.example.com",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "SigningPemPath": "/run/secrets/jwt-signing.pem",
    "KeyId": "prod-key-1"
  },
  "OAuth2": {
    "ClientSecret": "CHANGE_ME_oauth_client_secret_min_32_chars"
  },
  "Uploads": {
    "SigningSecret": "CHANGE_ME_upload_signing_secret_32chars!!",
    "SignedUrlLifetimeMinutes": 15
  },
  "RegistrationInvite": {
    "HmacPepper": "CHANGE_ME_registration_invite_pepper_32"
  },
  "AiService": {
    "GrpcAddress": "https://ai-worker.internal:50051",
    "WorkerAuthToken": "CHANGE_ME_ai_worker_token"
  },
  "Search": {
    "WorkerGrpcUrl": "https://search-worker.internal:50052",
    "WorkerAuthToken": "CHANGE_ME_search_worker_token"
  },
  "Push": {
    "WorkerGrpcUrl": "https://push-worker.internal:50053",
    "WorkerAuthToken": "CHANGE_ME_push_worker_token"
  },
  "Mail": {
    "WorkerGrpcUrl": "https://mailer.internal:50054",
    "WorkerAuthToken": "CHANGE_ME_mailer_worker_token"
  },
  "Redis": {
    "Configuration": "redis.internal:6379,ssl=true,password=CHANGE_ME"
  },
  "HardenedSecurity": {
    "EnforceWorkerTlsAndTokens": true,
    "EnforceJwtSigningPem": true,
    "RejectPlaceholderSecrets": true,
    "CertificateRevocationMode": "Online"
  }
}
