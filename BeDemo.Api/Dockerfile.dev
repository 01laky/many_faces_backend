FROM mcr.microsoft.com/dotnet/sdk:10.0

# Build context: many_faces_backend (parent of BeDemo.Api; many_faces_proto is ../many_faces_proto from the project).
WORKDIR /src/BeDemo.Api

RUN dotnet tool install --global dotnet-ef --version 10.0.5
ENV PATH="$PATH:/root/.dotnet/tools"

COPY ["BeDemo.Api/BeDemo.Api.csproj", "./"]
RUN dotnet restore

COPY ["BeDemo.Api/", "./"]
COPY ["many_faces_proto/", "../many_faces_proto/"]

EXPOSE 8000
EXPOSE 8001

ENTRYPOINT ["dotnet", "watch", "run"]
