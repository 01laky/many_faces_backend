# EditorConfig — many_faces_backend (tabs for C# and repo config)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4
tab_width = 4

[*.{cs,csx}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{json,yml,yaml,cjs,js,mjs}]
indent_style = tab
indent_size = 2
tab_width = 2

[*.{csproj,props,targets,sln}]
indent_style = tab
indent_size = 2
tab_width = 2

[*.md]
trim_trailing_whitespace = false

[*.resx]
indent_style = tab
indent_size = 2
tab_width = 2
